  "manifest_version": "1",

  "name": "MyBeats Music",
  "short_name": "MyBeats",
  "description": "Stream and share all your favorite music for free. MyBeats is a beautiful, fast PWA music player with offline support, album art, playlists, favorites, and more.",
  "dir": "auto",
  "lang": "en",
  "id": "/?pwa=true",
  "start_url": "https://mybeats.xo.je/",
