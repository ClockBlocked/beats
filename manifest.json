    "label": "MyBeats Music Player"
  }],

  "shortcuts": [{
    "name": "Now Playing",
    "short_name": "Playing",
    "description": "Jump to the currently playing song",
    "url": "/",
    "icons": [{
      "src": "/manifest/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png"
    }]
  },
    {
      "name": "Library",
      "short_name": "Library",
      "description": "Browse your full music library",
      "url": "/library",
      "icons": [{
        "src": "/manifest/icons/icon-96x96.png",
        "sizes": "96x96",
        "type": "image/png"
      }]
    },
    {
      "name": "Favorites",
      "short_name": "Favorites",
      "description": "Open your favorite songs, artists, and albums",
      "url": "/favorites",
      "icons": [{
        "src": "/manifest/icons/icon-96x96.png",
        "sizes": "96x96",
        "type": "image/png"
      }]
    },
    {
      "name": "Playlists",
      "short_name": "Playlists",
      "description": "View and manage your playlists",
      "url": "/playlists",
      "icons": [{
        "src": "/manifest/icons/icon-96x96.png",
        "sizes": "96x96",
        "type": "image/png"
      }]
    }],

  "share_target": {
    "action": "/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [{
        "name": "audio",
        "accept": [
          "audio/*",
          "audio/mpeg",
          "audio/mp3",
          "audio/ogg",
          "audio/wav",
          "audio/flac",
          "audio/m4a",
          "audio/aac"
        ]
      }]
    }
  },

  "protocol_handlers": [{
    "protocol": "web+mybeats",
    "url": "/?action=%s"
  },
    {
      "protocol": "web+music",
      "url": "/?search=%s"
    }],

  "file_handlers": [{
    "action": "/",
    "accept": {
      "audio/mpeg": [".mp3"],
      "audio/ogg": [".ogg"],
      "audio/wav": [".wav"],
      "audio/flac": [".flac"],
      "audio/x-m4a": [".m4a"],
      "audio/aac": [".aac"],
      "audio/mp4": [".mp4"]
    }
  }],

  "related_applications": [{
    "platform": "play",
    "url": "https://play.google.com/store/apps/details?id=com.mybeats.music"
  },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/mybeats-music/id0000000000"
    },
    {
      "platform": "windows",
      "url": "https://apps.microsoft.com/detail/mybeats-music/9NXXXXXXXXXX"
    }],
  "prefer_related_applications": false,

  "edge_side_panel": {
    "preferred_width": 380
  },

  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["focus-existing",
      "auto"]
  },

  "scope_extensions": [{
    "origin": "https://mybeats.xo.je"
  }]
}