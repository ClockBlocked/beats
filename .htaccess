# ================================================================
# SPA Routing — Apache mod_rewrite
#
# Ensures bookmarked URLs (e.g. /beats/artist/drake) resolve to
# index.html so the client-side router handles them.
# ================================================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /beats/

  # If the request is for an existing file or directory, serve it
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, route everything to index.html
  RewriteRule ^ index.html [L]
</IfModule>

# ================================================================
# Caching — immutable assets get long cache, HTML gets none
# ================================================================
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|woff2?)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ================================================================
# Compression — gzip text-based assets
# ================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
